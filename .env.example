HF_HOME="./.hf_cache"
PIP_CACHE_DIR="./.pip_cache"

# Set to true to use 'paraphrase-multilingual-MiniLM-L12-v2' (supports 50+ languages, ~500MB RAM)
# Set to false to use 'all-MiniLM-L6-v2' (English only, insanely fast, ~100MB RAM)
MULTILINGUAL_MODE=true

# Enable or Disable AI Tactical Cues Framework
# Set to false to run as a lightweight, pure transcription teleprompter (saves memory)
ENABLE_LOCAL_RAG=true
